<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.presenzadigitale\.com [NC]
  RewriteRule ^(.*)$ https://presenzadigitale.com/$1 [L,R=301]

  # Redirect .it to .com
  RewriteCond %{HTTP_HOST} ^(www\.)?presenzadigitale\.it [NC]
  RewriteRule ^(.*)$ https://presenzadigitale.com/$1 [L,R=301]

  # SPA Routing Fallback (for React/Vite)
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
