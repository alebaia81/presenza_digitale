{
  "trailingSlash": false,
  "redirects": [
    {
      "source": "https://www.presenzadigitale.com/(.*)",
      "destination": "https://presenzadigitale.com/$1",
      "permanent": true
    },
    {
      "source": "/prezzi",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|images|favicon|apple-touch|robots|sitemap).*)",
      "destination": "/index.html"
    }
  ]
}
