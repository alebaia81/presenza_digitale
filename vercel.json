{
  "trailingSlash": false,
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "https://www.presenzadigitale.com/(.*)",
      "destination": "https://presenzadigitale.com/$1",
      "permanent": true
    },
    {
      "source": "/prezzi",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/((?!assets|images|favicon|apple-touch|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
